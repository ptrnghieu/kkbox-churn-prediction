{
  "uid": "kkbox-api-health",
  "title": "API Health",
  "tags": ["kkbox"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(serving_http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "P99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(serving_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(serving_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(serving_http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(serving_http_requests_total[1m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "fixed", "fixedColor": "red" }, "min": 0, "max": 1 }
      }
    },
    {
      "id": 4,
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(serving_http_requests_in_progress) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(serving_http_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(serving_http_requests_total{status_code=~\"5..\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    }
  ],
  "schemaVersion": 38
}
